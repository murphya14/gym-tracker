generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "foreignKeys"
}

/**
 * ================= USER =================
 */

model User {
  id                     String   @id @default(cuid())
  dateCreated            DateTime @default(now()) @map("date_created")
  username               String   @unique
  password               String
  firstName              String   @map("first_name")
  lastName               String   @map("last_name")
  hasSeenLatestChangelog Boolean  @default(false) @map("has_seen_latest_changelog")

  workouts         WorkoutPlan[]
  routines         Routine[]
  sessions         Session[]
  completedSession CompletedSession[]
  activeSession    ActiveSession[]
  userPreferences  UserPreference[]
  userSetting      UserSetting?
  exerciseLogs     ExerciseLog[]

  @@map("user")
}

/**
 * ================= WORKOUT SYSTEM =================
 */

model WorkoutPlan {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  circuits  Circuit[]
  user      User?     @relation(fields: [userId], references: [id])
  userId    String?
  session   Session?  @relation(fields: [sessionId], references: [id])
  sessionId String?
}

model Circuit {
  id     String @id @default(cuid())
  name   String
  order  Int
  repeat Int?

  workout   WorkoutPlan @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  workoutId String

  exercises CircuitExercise[]
}

model CircuitExercise {
  id String @id @default(cuid())

  order Int
  reps  Int
  sets  Int

  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  exerciseId String

  circuit   Circuit @relation(fields: [circuitId], references: [id], onDelete: Cascade)
  circuitId String

  logs ExerciseLog[]
}

model Exercise {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  videoUrl    String?
  notes       String?

  type ExerciseType

  circuitExercises CircuitExercise[]
}

/**
 * ================= LOGS =================
 */

model ExerciseLog {
  id String @id @default(cuid())

  weight    Int?
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  circuitExercise   CircuitExercise @relation(fields: [circuitExerciseId], references: [id])
  circuitExerciseId String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@map("exercise_log")
}

/**
 * ================= SESSION SYSTEM =================
 */

model Session {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now()) @map("created_at")
  name        String
  description String?

  workouts WorkoutPlan[]

  routine   Routine? @relation(fields: [routineId], references: [id], onDelete: Cascade)
  routineId String?  @map("routine_id")

  days SessionDaysActive[]

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  completedSession CompletedSession[]
  activeSession    ActiveSession[]

  @@map("session")
}

model SessionDaysActive {
  id  String @id @default(cuid())
  day String

  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String  @map("session_id")

  @@map("session_days_active")
}

/**
 * ================= COMPLETED SESSION (FIXED) =================
 */

model CompletedSession {
  id                  String   @id @default(cuid())
  startedAt           DateTime @map("started_at")
  completedAt         DateTime @default(now()) @map("completed_at")
  percentageCompleted Int      @map("percentage_completed")

  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String  @map("session_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@map("completed_session")
}

/**
 * ================= SESSION STATE =================
 */

model ActiveSession {
  id        String   @id @default(cuid())
  startedAt DateTime @default(now()) @map("started_at")

  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String  @map("session_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@map("active_session")
}

/**
 * ================= ROUTINES =================
 */

model Routine {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now()) @map("created_at")
  name        String
  description String?
  isActive    Boolean  @default(false) @map("is_active")

  sessions Session[]

  user   User   @relation(fields: [userId], references: [id])
  userId String @map("user_id")

  @@unique([name, userId])
  @@map("routine")
}

/**
 * ================= USER SETTINGS =================
 */

model UserPreference {
  id         String     @id @default(cuid())
  preference Preference @map("preference")
  enabled    Boolean    @default(true)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@map("user_preference")
}

model UserSetting {
  id         String      @id @default(cuid())
  timezone   TimezoneMap @relation(fields: [timezoneId], references: [id], onDelete: Cascade)
  timezoneId String      @map("timezone_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique @map("user_id")

  @@map("user_setting")
}

model TimezoneMap {
  id      String @id @default(cuid())
  iana    String @unique @map("iana")
  display String @map("display")

  userSetting UserSetting[]

  @@map("timezone_map")
}

/**
 * ================= ENUMS =================
 */

enum Preference {
  CONFETTI_ON_SESSION_COMPLETION
  SHOW_ELAPSED_SECONDS_IN_ACTIVE_SESSION
}

enum ExerciseType {
  WEIGHTED
  DURATION
}
